# Environment
NODE_ENV=production
PORT=5000

# CORS (comma separated origins; add your Vercel domain here)
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?appName=Cluster0

# Admin credentials (change these in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-to-a-random-long-string

# Backend public URL (HTTPS in production — used as Flow endpoint URI and register form base)
BACKEND_URL=https://your-backend.onrender.com

# Frontend URL (production admin panel)
FRONTEND_URL=https://your-frontend.vercel.app

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_VERIFY_TOKEN=kavitha_pg_verify
META_GRAPH_VERSION=v22.0

# WhatsApp Flow (populated by `npm run flow:setup` or `npm run flow:create`)
WHATSAPP_FLOW_ID=
WHATSAPP_FLOW_STATUS=DRAFT

# Flow encryption keys (populated by `npm run flow:keys`)
FLOW_PRIVATE_KEY=
FLOW_PUBLIC_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Meta Native WhatsApp Pay — payment configuration created in WA Manager
META_PAYMENT_CONFIGURATION_NAME=
RAZORPAY_MID=

# Razorpay direct keys (only required if you also want to fall back to Payment Links)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google Sheets — Spreadsheet ID (sheet shared with service account email)
GOOGLE_SHEET_ID=
# Full service account JSON (single line, double-quoted). Paste your service account JSON below.
GOOGLE_SERVICE_ACCOUNT_KEY=
